# Copy this file to .env on your VPS and change the values.

# Public domain that points to the VPS. Example: cs.example.com
DOMAIN=cs.example.com

# Email used by Caddy/Let's Encrypt for TLS notices.
ACME_EMAIL=admin@example.com

# Game server settings
SERVER_NAME=Office CS 1.6
START_MAP=de_dust2
MAXPLAYERS=16
RCON_PASSWORD=change-this-rcon-password

# Host ports. You normally do not change these.
HLDS_PORT=27015
BRIDGE_PORT=27016
